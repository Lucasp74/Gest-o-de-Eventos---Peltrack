# Peltrack — exemplo de variáveis de ambiente.
# Copie para `.env` e preencha com os seus valores. O `.env` NUNCA vai para o git.

# ── Banco de dados (PostgreSQL / Neon) ──────────────────
# Use a conexão DIRETA (sem "-pooler"): o Prisma precisa dela para as migrations.
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/banco?sslmode=verify-full"

# ── Auth.js ─────────────────────────────────────────────
# Chave que assina as sessões. Gere uma com: npx auth secret
AUTH_SECRET=""
# OAuth do Google (Google Cloud Console → Credenciais → ID do cliente OAuth)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Cloudflare Turnstile (captcha do login administrativo) ──
# Em desenvolvimento, use as chaves de teste oficiais da Cloudflare
# (funcionam em qualquer domínio, inclusive localhost).
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ── Resend (envio de e-mails) ───────────────────────────
# Sem a chave, o sistema não quebra: o código de acesso sai no log do servidor.
RESEND_API_KEY=""
# Remetente. Enquanto o domínio não estiver verificado no Resend, o sandbox
# "onboarding@resend.dev" só entrega para o e-mail dono da conta.
MAIL_FROM="Peltrack <onboarding@resend.dev>"

# ── Pusher Channels (atualização em tempo real) ─────────
# Sem estas chaves o sistema funciona normalmente, apenas sem tempo real.
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="sa1"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="sa1"

# ── Mercado Pago (cobrança Pix de ingressos) ────────────
# Sem o token, eventos pagos exibem "pagamento indisponível" (não quebra).
# Atenção: o Pix exige uma chave Pix cadastrada na conta que vai receber.
MERCADO_PAGO_ACCESS_TOKEN=""
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=""
# Segredo de assinatura do webhook (painel do Mercado Pago → Webhooks).
MERCADO_PAGO_WEBHOOK_SECRET=""

# ── Vercel Blob (upload da imagem do evento) ────────────
# Opcional. Sem o token, em desenvolvimento o upload cai em /public/uploads.
BLOB_READ_WRITE_TOKEN=""

# ── Seed (credenciais iniciais do banco) ────────────────
# Usadas apenas por `npm run db:seed`. Defina valores fortes.
SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_DEMO_EMAIL=""
SEED_DEMO_PASSWORD=""
